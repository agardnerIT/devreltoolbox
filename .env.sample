# Copy this file to `.env` and fill in real values as needed.
# Only LANGDOCK_API_KEY is required for AI-powered features.

# Required for LangDock-backed generation, summaries, chapters, and metadata.
LANGDOCK_API_KEY=your_langdock_api_key_here

# Optional: default model used for LangDock requests across the app.
# Default: gpt-5-mini
LANGDOCK_MODEL=gpt-5-mini

# Optional Browser Recorder tuning for LangDock script generation.
# Request timeout in seconds.
# Default: 180
BROWSER_RECORDER_LANGDOCK_TIMEOUT=180

# Number of retries after the initial request fails.
# Default: 2
BROWSER_RECORDER_LANGDOCK_RETRIES=2

# Max tokens requested for generated Playwright scripts.
# Default: 6000
BROWSER_RECORDER_LANGDOCK_MAX_TOKENS=6000